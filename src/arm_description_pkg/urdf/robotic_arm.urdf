<?xml version="1.0"?>
<robot name="custom_6dof_arm_final">

  <material name="black">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.8 0.8 0.8 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.063" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.126"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.063" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.126"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_6_base" type="revolute">
    <parent link="base_link"/>
    <child link="link_shoulder"/>
    <origin xyz="0 0 0.126" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> 
    <limit lower="-1.5708" upper="1.5708" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="link_shoulder">
    <visual>
      <origin xyz="0 0 0.0075" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.015"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0075" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.015"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_5_shoulder" type="revolute">
    <parent link="link_shoulder"/>
    <child link="link_bicep"/>
    <origin xyz="0 0 0.015" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/> 
    <limit lower="-1.2217" upper="1.2217" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="link_bicep">
    <visual>
      <origin xyz="0 0 0.0525" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.04 0.105"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0525" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.04 0.105"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_4_elbow" type="revolute">
    <parent link="link_bicep"/>
    <child link="link_forearm"/>
    <origin xyz="0 0 0.105" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/> 
    <limit lower="-1.3963" upper="1.3963" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="link_forearm">
    <visual>
      <origin xyz="0 0 0.0725" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.035 0.145"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0725" rpy="0 0 0"/>
      <geometry>
        <box size="0.025 0.035 0.145"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_3_wrist_pitch" type="revolute">
    <parent link="link_forearm"/>
    <child link="link_wrist_roll"/>
    <origin xyz="0 0 0.145" rpy="0 0 0"/>
    <axis xyz="0 1 0"/> 
    <limit lower="-1.5708" upper="1.5708" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="link_wrist_roll">
    <visual>
      <origin xyz="0 0 0.0375" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.075"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0375" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.075"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_2_wrist_roll" type="revolute">
    <parent link="link_wrist_roll"/>
    <child link="link_gripper_base"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> 
    <limit lower="-1.3963" upper="1.3963" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="link_gripper_base">
    <visual>
      <origin xyz="0 0 0.0235" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.06 0.047"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0235" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.06 0.047"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_1_gripper" type="revolute">
    <parent link="link_gripper_base"/>
    <child link="link_gripper_left_finger"/>
    <origin xyz="0 0.015 0.047" rpy="-0.5236 0 0"/>
    <axis xyz="1 0 0"/> 
    <limit lower="-0.3491" upper="0.6981" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="link_gripper_left_finger">
    <visual>
      <origin xyz="0 0.0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0.0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_1_gripper_right" type="revolute">
    <parent link="link_gripper_base"/>
    <child link="link_gripper_right_finger"/>
    <origin xyz="0 -0.015 0.047" rpy="0.5236 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.6981" upper="0.3491" effort="10.0" velocity="1.0"/>
    <mimic joint="joint_1_gripper" multiplier="-1.0"/>
  </joint>

  <link name="link_gripper_right_finger">
    <visual>
      <origin xyz="0 0.0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0.0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_tcp" type="fixed">
    <parent link="link_gripper_base"/>
    <child link="gripper_center"/>
    <origin xyz="0 0 0.107" rpy="0 0 0"/>
  </joint>

  <link name="gripper_center"/>

</robot>