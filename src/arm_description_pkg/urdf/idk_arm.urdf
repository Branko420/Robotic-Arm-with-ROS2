<?xml version="1.0"?>
<robot name="custom_6dof_arm_final">

  <material name="black">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>

  <material name="silver">
    <color rgba="0.8 0.8 0.8 1.0"/>
  </material>

  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0"/>
  </material>

  <material name="green">
    <color rgba="0.0 1.0 0.0 1.0"/>
  </material>

  <!--
    Measured base height:
    18.8mm + 108mm = 126.8mm = 0.1268m
  -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.0634"/>
      <geometry>
        <cylinder radius="0.06" length="0.1268"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.0634"/>
      <geometry>
        <cylinder radius="0.06" length="0.1268"/>
      </geometry>
    </collision>
  </link>

  <!-- Group: arm_group -->
  <joint name="joint_6_base" type="revolute">
    <parent link="base_link"/>
    <child link="link_shoulder"/>
    <origin xyz="0 0 0.1268"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="10.0" velocity="1.0"/>
  </joint>

  <!--
    Measured base top to shoulder horn center:
    15.2mm = 0.0152m
  -->
  <link name="link_shoulder">
    <visual>
      <origin xyz="0 0 0.0076"/>
      <geometry>
        <cylinder radius="0.04" length="0.0152"/>
      </geometry>
      <material name="silver"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.0076"/>
      <geometry>
        <cylinder radius="0.04" length="0.0152"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_5_shoulder" type="revolute">
    <parent link="link_shoulder"/>
    <child link="link_bicep"/>
    <origin xyz="0 0 0.0152"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-1.2217" upper="1.2217" effort="10.0" velocity="1.0"/>
  </joint>

  <!--
    Measured shoulder horn center to elbow horn center:
    105.3mm = 0.1053m
  -->
  <link name="link_bicep">
    <visual>
      <origin xyz="0 0 0.05265"/>
      <geometry>
        <box size="0.03 0.04 0.1053"/>
      </geometry>
      <material name="orange"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.05265"/>
      <geometry>
        <box size="0.03 0.04 0.1053"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_4_elbow" type="revolute">
    <parent link="link_bicep"/>
    <child link="link_forearm"/>
    <origin xyz="0 0 0.1053"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-1.3963" upper="1.3963" effort="10.0" velocity="1.0"/>
  </joint>

  <!--
    Measured elbow horn center to wrist horn center:
    146.3mm = 0.1463m
  -->
  <link name="link_forearm">
    <visual>
      <origin xyz="0 0 0.07315"/>
      <geometry>
        <box size="0.025 0.035 0.1463"/>
      </geometry>
      <material name="silver"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.07315"/>
      <geometry>
        <box size="0.025 0.035 0.1463"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_3_wrist_pitch" type="revolute">
    <parent link="link_forearm"/>
    <child link="link_wrist_roll"/>
    <origin xyz="0 0 0.1463"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="10.0" velocity="1.0"/>
  </joint>

  <!--
    Measured wrist horn center to wrist-rotation horn top:
    74.7mm = 0.0747m
  -->
  <link name="link_wrist_roll">
    <visual>
      <origin xyz="0 0 0.03735"/>
      <geometry>
        <cylinder radius="0.02" length="0.0747"/>
      </geometry>
      <material name="orange"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.03735"/>
      <geometry>
        <cylinder radius="0.02" length="0.0747"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_2_wrist_roll" type="revolute">
    <parent link="link_wrist_roll"/>
    <child link="link_gripper_base"/>
    <origin xyz="0 0 0.0747"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.3963" upper="1.3963" effort="10.0" velocity="1.0"/>
  </joint>

  <!--
    Gripper base kept close to original.
    The measured total gripper/tool length is represented by tool0 below.
  -->
  <link name="link_gripper_base">
    <visual>
      <origin xyz="0 0 0.0235"/>
      <geometry>
        <box size="0.04 0.06 0.047"/>
      </geometry>
      <material name="silver"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.0235"/>
      <geometry>
        <box size="0.04 0.06 0.047"/>
      </geometry>
    </collision>
  </link>

  <!-- Simplified Gripper Joint for Setup Assistant -->
  <joint name="joint_1_gripper" type="revolute">
    <parent link="link_gripper_base"/>
    <child link="link_gripper_left_finger"/>
    <origin xyz="0 0.015 0.047"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.3491" upper="0.6981" effort="10.0" velocity="1.0"/>
  </joint>

  <link name="link_gripper_left_finger">
    <visual>
      <origin xyz="0 0 0.03"/>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
      <material name="orange"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.03"/>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
    </collision>
  </link>

  <!--
    Tool center point.

    Measured gripper length:
      at 90 degrees  = 104.7mm = 0.1047m
      at 130 degrees = 109.2mm = 0.1092m

    Current value uses 90 degree measurement.
    If you want the 130 degree measurement, change z from 0.1047 to 0.1092.
  -->
  <joint name="tool0_fixed_joint" type="fixed">
    <parent link="link_gripper_base"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.1047" rpy="0 0 0"/>
  </joint>

  <link name="tool0">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.008"/>
      </geometry>
      <material name="green"/>
    </visual>
  </link>

</robot>